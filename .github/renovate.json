{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>mono0x/renovate-config:dprint-plugins",
    "github>mono0x/renovate-config:hk-pkl"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "2 days",
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "actions",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchDepNames": [
        "!hk"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "mise",
      "schedule": [
        "on monday"
      ]
    }
  ]
}
