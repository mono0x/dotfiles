{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>mono0x/renovate-config:dprint-plugins",
    "github>mono0x/renovate-config:hk-pkl"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "2 days",
  "osvVulnerabilityAlerts": true,
  "group": {
    "commitMessageTopic": "{{#if upgrades.[1]}}{{{groupName}}}{{else}}{{{depName}}}{{/if}}"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^src/\\.chezmoiexternal\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "# renovate: currentValue=(?<currentValue>\\S+)\\s+url = \"https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentDigest>[0-9a-f]+)/",
        "# renovate: currentValue=(?<currentValue>\\S+)\\s+url = \"https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/(?<currentDigest>[0-9a-f]+)\\.tar\\.gz\""
      ],
      "datasourceTemplate": "github-digest"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^src/dot_config/sheldon/plugins\\.toml$/"
      ],
      "matchStrings": [
        "# renovate: currentValue=(?<currentValue>\\S+)\\s+github = \"(?<depName>[^\"]+)\"\\s+rev = \"(?<currentDigest>[0-9a-f]+)\""
      ],
      "datasourceTemplate": "github-digest"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "src/.chezmoiexternal.toml.tmpl"
      ],
      "groupName": "chezmoi externals",
      "schedule": [
        "on monday"
      ]
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "src/dot_config/sheldon/plugins.toml"
      ],
      "groupName": "sheldon plugins",
      "schedule": [
        "on monday"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "GitHub Actions",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "mise tools",
      "schedule": [
        "on monday"
      ]
    },
    {
      "matchDepNames": [
        "hk-pkl"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "mise tools",
      "schedule": [
        "on monday"
      ]
    }
  ]
}
