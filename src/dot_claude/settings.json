{
  "language": "japanese",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "DISABLE_INSTALLATION_CHECKS": "true"
  },
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm cat-file:*)",
      "Bash(pnpm cat-index:*)",
      "Bash(pnpm doctorlist:*)",
      "Bash(pnpm licenses:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm view:*)",
      "Bash(pnpm why:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(gh api:*)",
      "Bash(gh auth:*)",
      "Bash(gh codespace:*)",
      "Bash(gh gpg-key:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "auto"
  },
  "respondToBashCommands": false,
  "skipAutoPermissionPrompt": true,
  "plansDirectory": "./.claude/plans",
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "./gradlew:*",
      "ctx7:*",
      "hk:*",
      "gh:*",
      "git:*",
      "pnpm:*",
      "rtk gh:*",
      "rtk git:*",
      "rtk pnpm:*"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "rtk hook claude" },
          { "type": "command", "command": "$HOME/.claude/hooks/git-safe.sh" }
        ]
      }
    ]
  }
}
