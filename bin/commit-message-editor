#!/bin/bash
# Run the commit message editor for core.editor of git.
set -eu

detect_terminal_editor() {
  local parent_pid="$PPID"
  local depth=0
  local command_line

  while [ "${parent_pid}" -gt 1 ] 2>/dev/null && [ "${depth}" -lt 12 ]
  do
    command_line="$(ps -o command= -p "${parent_pid}" 2>/dev/null || true)"
    case "${command_line}" in
      *Code.app*|*code*)
        printf '%s\n' code
        return 0
        ;;
      *Zed.app*|*zed*)
        printf '%s\n' zed
        return 0
        ;;
    esac

    parent_pid="$(ps -o ppid= -p "${parent_pid}" 2>/dev/null || true)"
    parent_pid="${parent_pid// /}"
    [ -n "${parent_pid}" ] || break
    depth=$((depth + 1))
  done

  return 1
}

editor="$(detect_terminal_editor || true)"

if [ "${editor}" = 'code' ] && [ -x "$(command -v code)" ]
then
  exec code --wait "$@"
elif [ "${editor}" = 'zed' ] && [ -x /Applications/Zed.app/Contents/MacOS/cli ]
then
  exec /Applications/Zed.app/Contents/MacOS/cli --wait "$@"
elif [ -x "$(command -v nvim)" ]
then
  exec nvim "$@"
else
  exec vim "$@"
fi
