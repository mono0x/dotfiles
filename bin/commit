#!/bin/bash
# Generate a commit message with claude and commit.
set -eu

edit=
if [ "${1:-}" = '-e' ]; then
  edit=1
  shift
fi

if git diff --cached --quiet; then
  git add -A
  if git diff --cached --quiet; then
    echo 'commit: no changes' >&2
    exit 1
  fi
fi

prompt="Generate a single git commit message for the currently staged changes.

## Starting context

- Current git status:
$(rtk git status)

- Current branch: $(rtk git branch --show-current)

- Recent commits (for tone/style reference):
$(rtk git log --oneline -10 2>/dev/null || true)

## Investigation

The staged diff is not pre-loaded — fetch it yourself, and dig deeper whenever the diff alone is not enough to write a precise message. Suggested moves:
- Run \`git diff --cached\` (or \`git diff --cached -- <path>\` per file) to see the actual changes.
- Read source files for surrounding code, types, comments, or related callers when the diff is ambiguous.
- Use \`git log\`, \`git show\`, or \`git blame\` to recover prior intent.

Do not modify the repository or working tree. Keep tool usage proportionate to the change size.

## Output

Output ONLY the commit message text. Do not include any preamble, explanation, code fences, or trailing commentary.
Do not add any attribution lines such as 'Co-Authored-By: ...', 'Generated with ...', or '🤖' markers."

if [ "$#" -gt 0 ]; then
  prompt="$prompt

## Additional instructions

$*"
fi

message="$(
  printf '%s' "$prompt" | claude -p --model sonnet \
    --permission-mode auto \
    --tools Read Glob Grep Bash \
    --allowed-tools \
      Read Glob Grep \
      'Bash(git diff:*)' 'Bash(git status:*)' 'Bash(git log:*)' \
      'Bash(git show:*)' 'Bash(git branch:*)' \
      'Bash(rtk git diff:*)' 'Bash(rtk git status:*)' 'Bash(rtk git log:*)' \
      'Bash(rtk git show:*)' 'Bash(rtk git branch:*)' \
      'Bash(git blame:*)' 'Bash(git ls-files:*)' 'Bash(git rev-parse:*)'
)"

tmpfile="$(mktemp -t COMMIT_EDITMSG.XXXXXX)"
trap 'rm -f "$tmpfile"' EXIT
printf '%s\n' "$message" >"$tmpfile"

if [ -n "$edit" ]; then
  git commit --edit --file "$tmpfile"
else
  git commit --file "$tmpfile"
fi
