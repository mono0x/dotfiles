#!/usr/bin/env zsh
# Dummy shebang for shfmt
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# https://zenn.dev/enchan1207/articles/7b9d7d397b7d0d
# Skip /etc/zprofile so it does not re-run path_helper and clobber PATH order.
if [[ -x /usr/libexec/path_helper ]]; then
  setopt no_global_rcs # noka: ZC1971
  # path_helper outputs shell code; eval is the documented usage and contains no interpolated variables.
  eval "$(/usr/libexec/path_helper -s)" # noka: ZC1046,ZC1098
fi

typeset -U path cdpath fpath manpath

# Prepend pattern; arr+=(...) only appends so the suggested fix changes semantics.
# noka: ZC1071
path=(
  $HOME/google-cloud-sdk/bin(N-/)
  $HOME/.krew/bin(N-/)
  $HOME/bin(N-/)
  /Applications/Ghostty.app/Contents/MacOS(N-/)
  /Applications/Obsidian.app/Contents/MacOS(N-/)
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"(N-/)
  "/Applications/Cursor.app/Contents/Resources/app/bin"(N-/)
  "/Applications/CotEditor.app/Contents/SharedSupport/bin"(N-/)
  "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"(N-/)
  $path
)

# Prepend pattern; arr+=(...) only appends so the suggested fix changes semantics.
# noka: ZC1071
fpath=(
  $XDG_CONFIG_HOME/zsh/functions(N-/)
  $fpath
)

if [[ ! -x "$EDITOR" ]]; then
  export EDITOR=vim
fi

export LESS='-R'

if [[ $LANG != 'ja_JP.UTF-8' && $LANG != 'en_US.UTF-8' ]]; then
  export LANG=en_US.UTF-8
fi
if [[ -z "$LC_ALL" ]]; then
  export LC_ALL=en_US.UTF-8
fi

export GOPATH="$HOME"

export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# https://hk.jdx.dev/getting_started.html
export HK_PKL_BACKEND=pklr
