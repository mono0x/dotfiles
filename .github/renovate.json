{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "2 days",
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "actions",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "mise",
      "schedule": [
        "on monday"
      ]
    },
    {
      "matchPackageNames": [
        "jdx/hk"
      ],
      "groupName": "hk"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^hk\\.pkl$/"
      ],
      "matchStrings": [
        "releases/download/v(?<currentValue>\\d+\\.\\d+\\.\\d+)/",
        "hk@(?<currentValue>\\d+\\.\\d+\\.\\d+)#"
      ],
      "depNameTemplate": "hk-pkl",
      "packageNameTemplate": "jdx/hk",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
