{{ $refreshPeriod := "168h" -}}

{{ $boucleFrameworkVersion := "4302a712aa28edc60e9cf12d05f679d85408ef94" -}}

[".claude/hooks/git-safe.sh"]
type = "file"
url = "https://raw.githubusercontent.com/Bande-a-Bonnot/Boucle-framework/{{ $boucleFrameworkVersion }}/tools/git-safe/hook.sh"
executable = true

{{ $nvim := ".config/nvim" -}}

["{{ $nvim }}/pack/vendor/start/copilot.vim"]
type = "git-repo"
url = "https://github.com/github/copilot.vim"
refreshPeriod = "{{ $refreshPeriod }}"
clone.args = ["--depth", "1"]
pull.args = ["--ff-only"]

["{{ $nvim }}/pack/vendor/start/lualine.nvim"]
type = "git-repo"
url = "https://github.com/nvim-lualine/lualine.nvim"
refreshPeriod = "{{ $refreshPeriod }}"
clone.args = ["--depth", "1"]
pull.args = ["--ff-only"]

["{{ $nvim }}/pack/vendor/start/solarized.nvim"]
type = "git-repo"
url = "https://github.com/shaunsingh/solarized.nvim"
refreshPeriod = "{{ $refreshPeriod }}"
clone.args = ["--depth", "1"]
pull.args = ["--ff-only"]

["{{ $nvim }}/pack/vendor/start/vim-fugitive"]
type = "git-repo"
url = "https://github.com/tpope/vim-fugitive"
refreshPeriod = "{{ $refreshPeriod }}"
clone.args = ["--depth", "1"]
pull.args = ["--ff-only"]

["{{ $nvim }}/pack/vendor/start/vim-surround"]
type = "git-repo"
url = "https://github.com/anyakichi/vim-surround"
refreshPeriod = "{{ $refreshPeriod }}"
clone.args = ["--depth", "1"]
pull.args = ["--ff-only"]
